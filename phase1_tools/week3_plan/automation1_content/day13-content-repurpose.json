    {
      "parameters": {
        "jsCode": "// 1. Safe JSON Parsing\nlet c = {};\ntry {\n  // If the LLM returned markdown blocks like ```json ... ```, strip them out first\n  const rawContent = $json.choices[0].message.content.replace(/```json|```/g, '').trim();\n  c = JSON.parse(rawContent);\n} catch (e) {\n  throw new Error(\"Failed to parse LLM response. The returned content was not valid JSON: \" + e.message);\n}\n\n// 2. Safely capture the previous node source text (using .first() is safer in Code nodes)\nlet sourceText = \"\";\ntry {\n  sourceText = $('Set Input').first().json.source_text || \"\";\n} catch (e) {\n  // Fallback if 'Set Input' node isn't directly reachable or has a different structure\n  sourceText = \"\";\n}\n\n// 3. Map the fields safely\nreturn { \n  json: {\n    title: c.title || \"\",\n    hook: c.hook || \"\",\n    twitter_caption: c.twitter_caption || \"\",\n    linkedin_caption: c.linkedin_caption || \"\",\n    instagram_caption: c.instagram_caption || \"\",\n    // If hashtags is already a string, keep it; if array, join it; otherwise fallback to empty string\n    hashtags: Array.isArray(c.hashtags) \n      ? c.hashtags.join(' ') \n      : (c.hashtags || \"\"),\n    source_preview: sourceText.slice(0, 100),\n    status: 'ready',\n    created_at: $now.toISO()\n  } \n};"
      },
