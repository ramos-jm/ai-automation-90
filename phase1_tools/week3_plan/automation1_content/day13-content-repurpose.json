        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a social media copywriter. Reply with ONLY a valid JSON object (no markdown, no commentary) using exactly these keys: title (string), hook (string, one attention-grabbing opening line), twitter_caption (string, under 280 characters), linkedin_caption (string, 3-5 sentences, professional tone), instagram_caption (string, casual tone with 1-2 emoji), hashtags plus add a # in front (array of strings).\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ (\"Repurpose this source content for social media. Source:\\n\\n\" + $json.choices[0].message.content).toJsonString() }}\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" }\n}",
        "options": {}
      },
